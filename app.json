{
  "expo": {
    "name": "Calculator",
    "slug": "Calculator_using_React_Native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/FontImage.png",
    "scheme": "calculatorusingreactnative",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/AppImage.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.saikatpradhan777.Calculator_using_React_Native"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/FontImage.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/FontImage.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7989b8d-12a6-4e53-972a-8883ee9c2c7f"
      }
    }
  }
}
